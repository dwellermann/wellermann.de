---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";
import Hero from "../components/widgets/Hero.astro";
import Features from "../components/widgets/Features.astro";
import devImg from "../assets/images/dev_balanced.png";
import IchImg from "../assets/images/ich.jpeg";
import openSourceImg from "../assets/images/open-source.png";
import Content2 from "../components/widgets/Content2.astro";
import ServiceListLink from "../components/widgets/ServiceListLink.astro";
import Button from "../components/ui/Button.astro";
import { Icon } from "astro-icon/components";

const metadata = {
  title: `${siteConfig.name}`,
  description:
    "Internetpräsenz von Daniel Wellermann, BIM-Koordinator und Entwickler aus Velen. Experte für DESITE MD/VDC Manager, IFC, BIM-Prozesse, Softwareentwicklung im Bauwesen, Linux, Open Source, 3D-Druck und Home-Server-Infrastruktur.",
  ignoreTitleTemplate: true,
};
---

<BaseLayout {metadata}>
  <Hero
    title={`Daniel Wellermann<br class="hidden md:block" /> <span class="bg-linear-to-r from-blue-400 via-purple-400 to-pink-400 bg-clip-text text-transparent">Lösungen kein Selbstzweck</span>`}
    tagline="Gelernter Metallbauer, BIM-Coordinator & Entwickler"
    description="+20 Jahre Baubranche, +20 Jahre GNU/Linux. Ich bin der Typ der Probleme liebt und Lösungen findet."
    actions={[
      { variant: "primary", text: "Zum Blog", href: "/blog" },
      { variant: "secondary", text: "Docs on Codeberg", href: "https://codeberg.org/dwellermann", target: "_blank" , rel: "noopener noreferrer", icon: "lucide:mountain"}
    ]}
  />

  <Features
    id="features"
    classes={{ container: "min-h-screen flex flex-col justify-center" }}
    tagline="Themen-Säulen"
    title="Meine Spielwiese"
    subtitle="Hier teile ich mein Wissen und meine Erfahrungen."
    features={[
      {
        title: "Linux & Server (IT)",
        description:
          "Über 20 Jahre GNU/Linux-Erfahrung. Vom Ubuntu/Debian Server bis Fedora o. Arch: Meine Daten und Sicherheit stehen an erster Stelle. Ich liebe das GNU/Linux Ökosystem.",
        icon: "lucide:server",
        iconClass: "bg-blue-500/10 text-blue-400",
      },
      {
        title: "Gebäude & BIM",
        description:
          "Als hauptberuflicher BIM-Coordinator & Developer entwickle ich spezielle Tools/Prozesse für Bau und Betrieb. Ich steh drauf Rohdaten wie IFC zu verarbeiten: für die Bauphase ist das Geil, für Betrieb noch Geiler!",
        icon: "lucide:building",
        iconClass: "bg-purple-500/10 text-purple-400",
      },
      {
        title: "Tekkie & Macher",
        description:
          "Feierabend gibt es nicht. Unser Haus ist wie ein großes Experimentierfeld: Büro u. Werkstattkeller sind mit einer Treppe verbunden. Oben Ideen - Unten Umsetzung.",
        icon: "lucide:printer",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
    ]}
  />

<Content2
    id="services"
    classes={{ container: "min-h-screen flex flex-col justify-center" }}
    items={[
      {
        title: "Virtualisierung ohne Kompromisse",
        description:
          "Proxmox, LXC und Docker sind mein Fundament. Ich baue keine fragilen Systeme, sondern stabile Infrastrukturen, die genau das tun, was ich will – und nicht, was der Hersteller vorgibt.",
        icon: "lucide:server",
      },
      {
        title: "Meine Daten gehören mir",
        description:
          "Self-Hosting ist seit 20 Jahren für mich eine Grundhaltung. Alle wollen jetzt im Jahr 2026 Datensouveränität. Die gibt es für viele Probleme oft nur im Open-Source-Bereich; ich teste, unterstütze und hoffe, dass sich das Ökosystem weiterentwickelt.",
        icon: "lucide:lock",
      },
      {
        title: "Rohdaten fressen, Lösungen ausspucken",
        description:
          "IFC-Modelle sind für viele nur 3D-Bilder oder Visualisierungen. Ich ziehe die harten Fakten aus den Rohdaten und mache sie für die Planung, Realisierung und den Betrieb nutzbar. Für einen ordentlichen Export nerve ich gerne Autoren und CAD-Publisher.",
        icon: "lucide:box",
      },
      {
        title: "Kein Programmierer, sondern Problemlöser",
        description:
          "JavaScript, Go, Bash-Scripte, sogar Python (wenn’s sein muss). Ich entwickle Tools, um Probleme zu lösen. Domain-Driven Design ist nicht abstrakt: Die Fachlichkeit gibt den Takt vor.",
        icon: "lucide:terminal",
      },
    ]}
    image={IchImg}
    imageAlt="Daniel Wellermann"
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Digitales Handwerk.
      </h3>
      <p class="text-lg text-muted-foreground mb-4">
        Ich nenne es nicht 'IT-Services', ich nenne es Problemlösung. Hier ist der Stack, mit dem ich täglich arbeite, experimentiere und Prozesse optimiere – egal ob im Büro oder unten an der Werkbank.
      </p>
    </Fragment>
  </Content2>

  <Features
    id="faq"
    classes={{ container: "min-h-screen flex flex-col justify-center" }}
    tagline="Klartext"
    title="Häufige Fragen"
    subtitle="...und meine Antwort darauf"
    features={[
      {
        title: "Ist BIM nicht nur ein Hype für Großprojekte?",
        description:
          "BIM ist kein Hype, sondern digitales Handwerk. Wer behauptet, es sei zu kompliziert, hat oft nur Angst vor sauberen Daten. Ich nutze IFC-Rohdaten, um Fehler virtuell zu lösen, bevor sie auf der Baustelle echtes Geld und Nerven kosten. Wer nur bunte Bilder will, macht kein BIM. BTW: saubere IFCs gibts auch ohne AIA u. BAP :-P",
        icon: "lucide:database",
        iconClass: "bg-pink-500/10 text-pink-400",
      },
      {
        title: "Metallbau und Softwareentwicklung – wie passt das zusammen?",
        description:
          "Perfekt. Ob ich nun Stahlträger verschweiße oder Code schreibe: Die Denkweise ist dieselbe. Man braucht einen Plan, das richtige Werkzeug und den Willen, das Projekt bis zur letzten Schraube (oder Zeile Code) konsequent durchzuziehen. Handwerk ist Logik zum Anfassen.",
        icon: "lucide:hammer",
        iconClass: "bg-purple-500/10 text-purple-400",
      },

{
        title: "Cloud, vServer oder Hardware im Keller ?",
        description:
          "Kommt drauf an, was ich erreichen will. Sensible Daten bleiben physisch im eigenen Haus, Dienste mit hoher Erreichbarkeit kommen auf gemietetem Server aber unter meiner Kontrolle. Das ist der entscheidende Unterschied zu SaaS-Silos wie MS365 oder Google. Wartung und Sicherheit sind dabei das wichtigste Thema: Backup, Audits gehören Automatisiert. Ich baue lieber neue Tools, statt händisch Backups oder Updates zu machen.",
        icon: "lucide:shield-check",
        iconClass: "bg-primary/10 text-primary",
      },
    ]}
  />

   <Content2
    id="opensource"
    classes={{ container: "min-h-screen flex flex-col justify-center" }}
    items={[]}
    image={openSourceImg}
    imageAlt="Community and Open Source"
    isReversed={true}
    actions={[
      { variant: "primary", text: "Mein Herzblut auf GitHub", href: "https://github.com/dwellermann", icon: "lucide:github" }
    ]}
  >
    <Fragment>
      <h3 class="text-2xl font-bold tracking-tight sm:text-3xl mb-2">
        Open Source
      </h3>
      Seit ich 15 bin, ist GNU/Linux mein Zuhause. Mit 17 habe ich mein erstes PHP-Liga-System für Counter-Strike 1.6 gehostet. Ich war damals kein Entwickler ich war Anwender! Nächte durchgetestet, Feedback gegeben und in Foren kostenlosen Support geliefert war mein Beitrag.
      <br /><br />
      Das ist das Fundament, das heute oft vergessen wird: Community besteht nicht nur aus Elite-Codern, sondern aus Testern, Dokumentierern und Supportern. Dieses offene Wissen ist der einzige Grund, warum moderne KI heute überhaupt existiert. Denn eines ist klar: Closed Source hat KI sicher nicht groß gemacht!
      <br /><br />
      Was mich dabei richtig abfuckt: Dass die Industrie Milliarden mit diesem Wissen scheffelt, während für die Leute an der Basis oft nicht mal ein Kaffee rausspringt. Meine Tools und Configs auf GitHub sind mein Respekt an dieses Handwerk und an jeden, der Wissen teilt, statt es einzusperren.
    </Fragment>
  </Content2>

  <div class="relative px-4 py-16 sm:px-6 mx-auto max-w-7xl lg:px-8 lg:py-20 text-center">
    <h2 class="text-3xl font-bold tracking-tight sm:text-4xl mb-6">
      Interesse an einem Austausch oder hast du Fragen zu meinen Docs?
    </h2>
    <div class="flex flex-col sm:flex-row justify-center gap-4">
      <Button variant="primary" size="lg" href="/contact">
        <Icon name="lucide:mail" class="w-5 h-5 mr-2 -ml-1" />
        Kontakt aufnehmen
      </Button>
    </div>
  </div>

  {/*
  <ServiceListLink
    title="Netzwerk"
    subtitle="Wo du mich sicher erreichen kannst"
    services={[
      ...siteConfig.socialLinks.filter((social) => !["Facebook"].includes(social.name)).map((social) => (
        {
          name: social.name,
          description: social.describe,
          icon: `${social.icon}`,
          link: social.href,
        }
      ))
    ]}
  />
  */}
</BaseLayout>
