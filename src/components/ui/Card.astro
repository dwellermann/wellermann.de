---
interface Props {
  class?: string;
  href?: string;
  ariaLabel?: string;
}

const { class: className, href, ariaLabel, ...rest } = Astro.props;

const Tag = href ? "a" : "div";
---

<Tag
  href={href}
  aria-label={href ? ariaLabel : undefined}
  class:list={[
    "bg-card p-8 rounded-2xl border border-border shadow-sm transition-all hover:border-primary/50",
    className,
  ]}
  {...rest}
>
  <slot />
</Tag>
